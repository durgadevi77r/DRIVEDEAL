# DriveDeal Backend Environment Variables
# Copy these into a file named ".env" inside the "backend" folder.

# Backend port (optional)
PORT=5000

# Admin email address to receive enquiry notifications
ADMIN_EMAIL=drivedealvk@gmail.com

# Gmail SMTP (TLS) for sending enquiry notification emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password

# Optional: enable SMTP debug logs in console
SMTP_DEBUG=false

# Notes:
# - Gmail requires an App Password (enable 2-Step Verification, then create an App Password for Mail)
# - If SMTP_USER/SMTP_PASS are missing, backend will fall back to JSON transport (logs email to console)

